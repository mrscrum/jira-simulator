{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "/usr/local/bin/docker",
      "runtimeArgs": ["compose", "-f", "docker-compose.yml", "-f", "docker-compose.dev.yml", "up", "--build", "backend"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "cd frontend && PATH=/usr/local/bin:$PATH /usr/local/bin/node node_modules/.bin/vite --host 0.0.0.0"],
      "port": 5173
    },
    {
      "name": "boxplot-prototype",
      "runtimeExecutable": "/usr/bin/python3",
      "runtimeArgs": ["-m", "http.server", "8765", "--directory", "."],
      "port": 8765
    }
  ]
}
